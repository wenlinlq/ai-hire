#!/usr/bin/env node

/**
 * Module dependencies.
 */

var app = require("../app");
var debug = require("debug")("server:server");
var http = require("http");
const { connectDB } = require("../db/db");

/**
 * Get port from environment and store in Express.
 */

var port = normalizePort(process.env.PORT || "3000");
app.set("port", port);

/**
 * Create HTTP server.
 */

var server = http.createServer(app);

/**
 * Start server after database connection
 */
async function startServer() {
  try {
    // 连接数据库
    await connectDB();

    // 导入用户模型并初始化索引
    const userModel = require("../models/userModel");
    await userModel.initIndexes();

    // 导入团队模型并初始化索引
    const teamModel = require("../models/teamModel");
    await teamModel.initIndexes();

    // 导入岗位模型并初始化索引
    const positionModel = require("../models/positionModel");
    await positionModel.initIndexes();

    // 导入收藏模型并初始化索引
    const favoriteModel = require("../models/favoriteModel");
    await favoriteModel.initIndexes();

    // 导入简历模型并初始化索引
    const resumeModel = require("../models/resumeModel");
    await resumeModel.initIndexes();

    // 导入面试题库模型并初始化索引
    const questionBankModel = require("../models/questionBankModel");
    await questionBankModel.initIndexes();

    // 导入投递模型并初始化索引
    const deliveryModel = require("../models/deliveryModel");
    await deliveryModel.initializeIndexes();

    // 导入AI预面试模型并初始化索引
    const aiPreInterviewModel = require("../models/aiPreInterviewModel");
    await aiPreInterviewModel.initializeIndexes();

    // 导入面试邀请模型并初始化索引
    const interviewInvitationModel = require("../models/interviewInvitationModel");
    await interviewInvitationModel.initializeIndexes();

    // 导入通知模型并初始化索引
    const notificationModel = require("../models/notificationModel");
    await notificationModel.initializeIndexes();

    console.log("Database indexes initialized successfully");

    // 启动服务器
    server.listen(port);
    server.on("error", onError);
    server.on("listening", onListening);
  } catch (error) {
    console.error("启动服务器失败:", error);
    process.exit(1);
  }
}

// 启动服务器
startServer();

/**
 * Normalize a port into a number, string, or false.
 */

function normalizePort(val) {
  var port = parseInt(val, 10);

  if (isNaN(port)) {
    // named pipe
    return val;
  }

  if (port >= 0) {
    // port number
    return port;
  }

  return false;
}

/**
 * Event listener for HTTP server "error" event.
 */

function onError(error) {
  if (error.syscall !== "listen") {
    throw error;
  }

  var bind = typeof port === "string" ? "Pipe " + port : "Port " + port;

  // handle specific listen errors with friendly messages
  switch (error.code) {
    case "EACCES":
      console.error(bind + " requires elevated privileges");
      process.exit(1);
      break;
    case "EADDRINUSE":
      console.error(bind + " is already in use");
      process.exit(1);
      break;
    default:
      throw error;
  }
}

/**
 * Event listener for HTTP server "listening" event.
 */

function onListening() {
  var addr = server.address();
  var bind = typeof addr === "string" ? "pipe " + addr : "port " + addr.port;
  debug("Listening on " + bind);
}
